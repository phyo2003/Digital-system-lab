library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity comp_3bit is
    Port ( a : in  STD_LOGIC_VECTOR (2 downto 0); -- Input A (3 bits)
           b : in  STD_LOGIC_VECTOR (2 downto 0); -- Input B (3 bits)
           gt : out STD_LOGIC;                    -- A > B
           lt : out STD_LOGIC;                    -- A < B
           eq : out STD_LOGIC);                   -- A = B
end comp_3bit;

architecture Dataflow of comp_3bit is
begin
    -- Concurrent Assignments (Logic Gates)
    gt <= '1' when (a > b) else '0';
    lt <= '1' when (a < b) else '0';
    eq <= '1' when (a = b) else '0';
end Dataflow;



architecture Structural of comp_3bit is
    signal e2, e1, e0 : std_logic;
begin
    -- Bit-wise equality wires
    e2 <= not (a(2) xor b(2));
    e1 <= not (a(1) xor b(1));
    e0 <= not (a(0) xor b(0));

    -- Structural Output Logic
    eq <= e2 and e1 and e0;
    
    gt <= (a(2) and not b(2)) or 
          (e2 and a(1) and not b(1)) or 
          (e2 and e1 and a(0) and not b(0));
          
    lt <= (not a(2) and b(2)) or 
          (e2 and not a(1) and b(1)) or 
          (e2 and e1 and not a(0) and b(0));
end Structural;


