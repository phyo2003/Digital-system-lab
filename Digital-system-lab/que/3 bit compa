end tb_comp_3bit;

architecture Behavioral of tb_comp_3bit is

    -- 1. Component Declaration for the Unit Under Test (UUT)
    component comp_3bit
        Port ( a : in  STD_LOGIC_VECTOR (2 downto 0);
               b : in  STD_LOGIC_VECTOR (2 downto 0);
               gt : out STD_LOGIC;
               lt : out STD_LOGIC;
               eq : out STD_LOGIC);
    end component;

    -- 2. Signal Declarations (to connect to the UUT)
    signal a_tb  : STD_LOGIC_VECTOR(2 downto 0) := "000";
    signal b_tb  : STD_LOGIC_VECTOR(2 downto 0) := "000";
    signal gt_tb : STD_LOGIC;
    signal lt_tb : STD_LOGIC;
    signal eq_tb : STD_LOGIC;

begin

    -- 3. Instantiate the UUT (Unit Under Test)
    uut: comp_3bit port map (
          a => a_tb,
          b => b_tb,
          gt => gt_tb,
          lt => lt_tb,
          eq => eq_tb
        );

    -- 4. Stimulus Process
    stim_proc: process
    begin		
        -- Test Case 1: Equality (000 vs 000)
        a_tb <= "000"; b_tb <= "000";
        wait for 100 ns; -- Observe eq_tb = '1'

        -- Test Case 2: A > B (111 vs 011)
        a_tb <= "111"; b_tb <= "011";
        wait for 100 ns; -- Observe gt_tb = '1'

        -- Test Case 3: A < B (010 vs 100)
        a_tb <= "010"; b_tb <= "100";
        wait for 100 ns; -- Observe lt_tb = '1'

        -- Test Case 4: Boundary Case (110 vs 111)
        a_tb <= "110"; b_tb <= "111";
        wait for 100 ns; -- Observe lt_tb = '1'

        wait; -- Stops the simulation
    end process;

end Behavioral;
