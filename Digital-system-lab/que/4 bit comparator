#1. Combinational Logic: 4-bit Magnitude ComparatorQuestion: Compare two 4-bit numbers ($A$ and $B$) and light up LEDs for Greater, Lesser, or Equal.
library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity comparator_4bit is
    Port ( A, B : in  STD_LOGIC_VECTOR (3 downto 0);
           Greater, Lesser, Equal : out STD_LOGIC);
end comparator_4bit;

architecture Dataflow of comparator_4bit is
begin
    -- Simple concurrent assignments
    Greater <= '1' when (A > B) else '0';
    Lesser  <= '1' when (A < B) else '0';
    Equal   <= '1' when (A = B) else '0';
end Dataflow;
